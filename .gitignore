# ==========================================
# LIQUID COMPUTE POOL - Master Ignore List
# ==========================================

# --- Databases (CRITICAL: Do not leak real or staging data) ---
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal
cga_app.db
backend/cga_staging.db

# --- Secrets & Environment Config ---
# This pattern matches .env, .env.local, .env.staging, etc.
.env*
backend/.env*
frontend/.env*

# --- Python / Backend ---
backend/.venv/
backend/__pycache__/
backend/*.pyc
.venv/
__pycache__/
*.py[cod]
*$py.class
pip-log.txt
pip-delete-this-directory.txt
.python-version

# --- Node / Frontend ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
.next/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# --- Docker ---
# We keep the .yml files, but ignore local data volumes if you add them later
.docker/

# --- OS Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Testing / Staging Artifacts ---
.pytest_cache/
.coverage
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.log

# --- Native Clients ---
/native-clients/